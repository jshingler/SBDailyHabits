# Copy this file to .env and fill in your values.
# .env is listed in .gitignore — never commit it (it contains secrets).

APP_NAME=SBDailyHabits
APP_VERSION=1.0.0

DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_HOST=
DATABASE_PORT=5432

# Get your token at https://www.notion.so/my-integrations
NOTION_TOKEN=secret_YOUR_TOKEN_HERE
NOTION_URL=https://api.notion.com/v1
NOTION_VERSION=2022-06-28

# Database IDs — found in the URL of each Notion database page
DAILY_DATABASE_ID=your-daily-tracking-db-id
HABITS_DATABASE_ID=your-daily-habits-db-id
HABITS_MASTER_DATABASE_ID=your-habits-master-db-id
DAILY_STATS_PAGE_ID=your-daily-stats-page-id
